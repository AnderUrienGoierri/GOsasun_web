        <mxCell id="E6" value="Gaurko listadoa erakutsi" style="html=1;verticalAlign=bottom;endArrow=open;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="350" y="620" as="sourcePoint"/><mxPoint x="150" y="620" as="targetPoint"/></mxGeometry>
