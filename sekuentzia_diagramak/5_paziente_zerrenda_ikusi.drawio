        <mxCell id="L3" value="Kontrola" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="500" y="80" width="100" height="650" as="geometry"/>
        </mxCell>
        <mxCell id="L4" value="Pazientea" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="100" height="650" as="geometry"/>
        </mxCell>
        
        <mxCell id="E1" value="pazienteZerrendaIkusi(gaurkoData)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="160" as="sourcePoint"/><mxPoint x="350" y="160" as="targetPoint"/></mxGeometry>
        </mxCell>
        
        <mxCell id="E2" value="lortuPazienteZerrenda(gaurkoData)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="350" y="210" as="sourcePoint"/><mxPoint x="550" y="210" as="targetPoint"/></mxGeometry>
        </mxCell>
        
        <mxCell id="E_DB" value="datuak = datubasetikLortu(idMedikua, gaurkoData)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=horizontal;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="250" as="sourcePoint"/><mxPoint x="550" y="290" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="580" y="270"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="Loop1" value="loop&#10;[i = 0 .. count(datuak)]" style="shape=umlFrame;whiteSpace=wrap;html=1;width=160;height=30;boundedLbl=1;verticalAlign=top;align=left;spacingLeft=5;" vertex="1" parent="1">
          <mxGeometry x="460" y="310" width="320" height="150" as="geometry"/>
        </mxCell>
        
        <mxCell id="E3" value="p = new Pazientea(datuak[i])" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="350" as="sourcePoint"/><mxPoint x="750" y="350" as="targetPoint"/></mxGeometry>
        </mxCell>
        
        <mxCell id="E4" value="p" style="html=1;verticalAlign=bottom;endArrow=open;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="750" y="400" as="sourcePoint"/><mxPoint x="550" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        
        <mxCell id="E_ADD" value="z.add(p)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=horizontal;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="420" as="sourcePoint"/><mxPoint x="550" y="450" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="580" y="435"/>
            </Array>          
          </mxGeometry>
        </mxCell>

        <mxCell id="E5" value="z (Paziente[] array-a)" style="html=1;verticalAlign=bottom;endArrow=open;edgeStyle=elbowEdgeStyle;elbow=vertical;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="550" y="520" as="sourcePoint"/><mxPoint x="350" y="520" as="targetPoint"/></mxGeometry>
        </mxCell>
        
        <mxCell id="E_GRID" value="txertatuDataGrid(z)" style="html=1;verticalAlign=bottom;endArrow=block;edgeStyle=elbowEdgeStyle;elbow=horizontal;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="350" y="550" as="sourcePoint"/><mxPoint x="350" y="580" as="targetPoint"/>
